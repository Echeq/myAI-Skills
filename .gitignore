# AI agent instructions (not for human collaborators)
/AGENTS.md

# Agent-generated config (regenerated by @ai-router --init or similar)
opencode.json
opencode.jsonc

# Operational artifacts (logs, generated reports, session memory)
docs/log/
docs/ai-audit/
docs/audit/
docs/auto-report/
docs/ai-init/

# Session memory (agent-generated)
.agents/memory/
!.agents/memory/*/.gitkeep
!.agents/memory/*/assets/plan/.gitkeep
!.agents/memory/*/assets/state/.gitkeep

# Legacy skill runtime artifacts (migrated to .agents/memory/ — keep ignored until cleaned)
.agents/skills/ai-router/assets/plan/Plan_*.md
.agents/skills/ai-router/assets/state/
.agents/skills/ai-orchestrator/assets/plan/Plan_*.md
.agents/skills/ai-orchestrator/assets/plan/plan_input.json
.agents/skills/ai-orchestrator/assets/state/

# Python cache (generated by dag.py)
__pycache__/
*.pyc

# Node modules (if any skill adds them in the future)
node_modules/

# Environment files (generated by @ai-env --init)
.env
.env.local
.env.*.local

# Temp & backup artifacts (defensive)
*.log
*.tmp
*.bak

# IDE/editor config (if generated)
.vscode/
.idea/
*.code-workspace

# OS files
.DS_Store
Thumbs.db
